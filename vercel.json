{
  "rewrites": [
    { "source": "/beta", "destination": "/submit/index.html" }
  ],
  "headers": [
    {
      "source": "/cep-badge-kit",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/cep-badge-kit/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ],
  "redirects": [
    { "source": "/about-jeffrey-anthony", "destination": "/about#founder", "permanent": true },
    { "source": "/founder", "destination": "/about#founder", "permanent": true },
    { "source": "/news-events", "destination": "/news", "permanent": true },
    { "source": "/get-certified", "destination": "/cep-submission", "permanent": true },
    { "source": "/apply-for-certification", "destination": "/cep-submission", "permanent": true },
    { "source": "/submit", "destination": "/cep-submission", "permanent": false },
    { "source": "/certificate-of-embodied-production-cep", "destination": "/standards", "permanent": true },
    { "source": "/certified-significant-form", "destination": "/standards", "permanent": true },
    { "source": "/why-it-matters", "destination": "/about", "permanent": true },
    { "source": "/a2im", "destination": "/", "permanent": false },
    { "source": "/research/perfect-music-democracy.pdf", "destination": "/research/perfect-music-democracy", "permanent": true },
    { "source": "/research/listening-to-ai-25-years.pdf", "destination": "/research/listening-to-aimusic-25-years", "permanent": true },
    { "source": "/research/listening-to-ai-25-years", "destination": "/research/listening-to-aimusic-25-years", "permanent": true }
  ]
}
